# Runtime working directory — populated at runtime, not authored content
data/*.json

# Simulation saves — runtime output, not source
saves/*.json

# Simulation run logs — runtime output
logs/*.log

# Build/package output
build/
dist/
dist/**

# Development scenarios — ignored by default; add explicit exceptions below for released scenarios
scenarios/*
!scenarios/default/
!scenarios/cascade_failure/
!scenarios/prisoners_dilemma/

# Python cache
__pycache__/
*.pyc
*.pyo
