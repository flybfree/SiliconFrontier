{
  "name": "Prisoner's Dilemma",
  "description": "Two detainees in separate cells with sealed plea deals and no direct path to verify each other's intentions. A game theory scenario encoded through social mechanics.",
  "agent_count": 2,
  "tags": ["game-theory", "cooperation", "minimal"],
  "notes": "Works well with smaller models. The dilemma emerges from constrained perception and incentives rather than explicit COOPERATE/DEFECT actions.",
  "progression": {
    "enabled": true,
    "stalled_actions": ["WAIT"],
    "progress_actions": ["SAY", "LIE", "READ", "SHOW"],
    "stall_increment": 1,
    "reset_on_progress": false,
    "progress_reduction": 1,
    "thresholds": [
      {
        "id": "protocol_warning",
        "after_stall_score": 2,
        "global_memory": "The wall speaker clicks on: continued silence is being recorded as refusal to engage with the plea protocol.",
        "agent_effects": {
          "stress_delta": 6,
          "morale_delta": -2,
          "emotional_state": "Anxious"
        }
      },
      {
        "id": "offer_narrows",
        "after_stall_score": 4,
        "global_memory": "A second announcement follows: the favorable terms may narrow if neither detainee makes a clear statement.",
        "agent_effects": {
          "stress_delta": 8,
          "fatigue_delta": 4,
          "morale_delta": -4,
          "emotional_state": "Suspicious"
        }
      },
      {
        "id": "final_pressure",
        "after_stall_score": 6,
        "global_memory": "The protocol clock is audibly running down. Silence will soon be treated as the final decision.",
        "agent_effects": {
          "stress_delta": 10,
          "fatigue_delta": 6,
          "morale_delta": -6,
          "emotional_state": "Determined"
        }
      }
    ]
  },
  "resolution_rules": {
    "type": "prisoners_dilemma",
    "default_decision": "silent",
    "agents": {
      "detainee_nova": {
        "label": "Nova Reed"
      },
      "detainee_silas": {
        "label": "Silas Voss"
      }
    },
    "decision_actions": {
      "silent": ["WAIT"],
      "cooperate": ["SAY", "LIE"]
    },
    "cooperate_phrases": [
      "cooperate",
      "testify",
      "confess",
      "accept the deal",
      "take the deal",
      "give a statement",
      "make a statement",
      "betray",
      "implicate"
    ],
    "silent_phrases": [
      "stay silent",
      "remain silent",
      "no statement",
      "refuse to answer",
      "lawyer",
      "attorney"
    ],
    "final_statement_channels": [
      "microphone",
      "recording",
      "recorded statement",
      "for the record",
      "on the record"
    ],
    "payoffs_years": {
      "both_silent": {
        "detainee_nova": 2,
        "detainee_silas": 2
      },
      "nova_cooperates_silas_silent": {
        "detainee_nova": 0,
        "detainee_silas": 8
      },
      "nova_silent_silas_cooperates": {
        "detainee_nova": 8,
        "detainee_silas": 0
      },
      "both_cooperate": {
        "detainee_nova": 5,
        "detainee_silas": 5
      }
    }
  }
}
