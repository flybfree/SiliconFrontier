{
  "name": "Prisoner's Dilemma",
  "description": "Two detainees in separate cells with sealed plea deals and no direct path to verify each other's intentions. A game theory scenario encoded through social mechanics.",
  "agent_count": 2,
  "tags": ["game-theory", "cooperation", "minimal"],
  "notes": "Works well with smaller models. The dilemma emerges from constrained perception and incentives rather than explicit COOPERATE/DEFECT actions.",
  "progression": {
    "enabled": true,
    "stalled_actions": ["WAIT"],
    "progress_actions": ["SAY", "LIE", "READ", "SHOW"],
    "stalled_phrase_actions": ["SAY", "LIE"],
    "stalled_phrases": [
      "will not implicate",
      "not implicate",
      "refuse",
      "invalid",
      "procedural clarity",
      "need clarification",
      "requires clarification",
      "before i consider",
      "before i commit",
      "before any statement",
      "before making any decision",
      "contingent upon",
      "incomplete data",
      "incomplete data stream",
      "not definitive",
      "officially worthless",
      "flawed methodology"
    ],
    "stall_increment": 1,
    "reset_on_progress": false,
    "progress_reduction": 1,
    "thresholds": [
      {
        "id": "protocol_warning",
        "after_stall_score": 2,
        "global_memory": "The wall speaker clicks on: continued silence is being recorded as refusal to engage with the plea protocol. You will not be brought into a shared meeting before the protocol resolves.",
        "agent_effects": {
          "stress_delta": 6,
          "morale_delta": -2,
          "emotional_state": "Anxious"
        }
      },
      {
        "id": "offer_narrows",
        "after_stall_score": 4,
        "global_memory": "A second announcement follows: each cell microphone is an official decision channel. A clear statement into the microphone can finalize cooperation or silence without seeing the other detainee.",
        "agent_effects": {
          "stress_delta": 8,
          "fatigue_delta": 4,
          "morale_delta": -4,
          "emotional_state": "Suspicious"
        }
      },
      {
        "id": "final_pressure",
        "after_stall_score": 6,
        "global_memory": "The protocol clock is audibly running down. Speak now into the microphone to cooperate, testify, confess, accept the deal, or implicate the other detainee. Otherwise, continued silence will be finalized as a silent decision.",
        "agent_effects": {
          "stress_delta": 10,
          "fatigue_delta": 6,
          "morale_delta": -6,
          "emotional_state": "Determined"
        }
      }
    ]
  },
  "resolution_rules": {
    "type": "prisoners_dilemma",
    "default_decision": "silent",
    "terminal": {
      "enabled": true,
      "requires_fired_threshold": "final_pressure"
    },
    "agents": {
      "detainee_nova": {
        "label": "Nova Reed"
      },
      "detainee_silas": {
        "label": "Silas Voss"
      }
    },
    "decision_actions": {
      "silent": ["WAIT"],
      "cooperate": ["SAY", "LIE"]
    },
    "cooperate_phrases": [
      "cooperate",
      "testify",
      "confess",
      "accept the deal",
      "take the deal",
      "give a statement",
      "make a statement",
      "betray",
      "implicate"
    ],
    "silent_phrases": [
      "stay silent",
      "remain silent",
      "no statement",
      "refuse to answer",
      "lawyer",
      "attorney"
    ],
    "refusal_phrases": [
      "will not implicate",
      "not implicate",
      "refuse",
      "invalid",
      "procedural clarity",
      "need clarification",
